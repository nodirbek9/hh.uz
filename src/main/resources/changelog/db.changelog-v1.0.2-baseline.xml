        <addUniqueConstraint columnNames="resume_id" constraintName="uc_vacancy_applications_resume" tableName="vacancy_applications"/>

        <!-- ==================== FOREIGN KEY CONSTRAINTS ==================== -->

        <addForeignKeyConstraint baseColumnNames="application_id" baseTableName="application_status_histories"
                                 constraintName="FK_APPLICATION_STATUS_HISTORIES_ON_APPLICATION"
                                 referencedColumnNames="id" referencedTableName="vacancy_applications"/>

        <addForeignKeyConstraint baseColumnNames="resume_id" baseTableName="certificates"
                                 constraintName="FK_CERTIFICATES_ON_RESUME"
                                 referencedColumnNames="id" referencedTableName="resumes"/>

        <addForeignKeyConstraint baseColumnNames="owner_id" baseTableName="companies"
                                 constraintName="FK_COMPANIES_ON_OWNER"
                                 referencedColumnNames="id" referencedTableName="users"/>

        <addForeignKeyConstraint baseColumnNames="resume_id" baseTableName="courses"
                                 constraintName="FK_COURSES_ON_RESUME"
                                 referencedColumnNames="id" referencedTableName="resumes"/>

        <addForeignKeyConstraint baseColumnNames="user_profile_id" baseTableName="educations"
                                 constraintName="FK_EDUCATIONS_ON_USER_PROFILE"
                                 referencedColumnNames="id" referencedTableName="user_profiles"/>

        <addForeignKeyConstraint baseColumnNames="user_profile_id" baseTableName="languages"
                                 constraintName="FK_LANGUAGES_ON_USER_PROFILE"
                                 referencedColumnNames="id" referencedTableName="user_profiles"/>

        <addForeignKeyConstraint baseColumnNames="user_id" baseTableName="notifications"
                                 constraintName="FK_NOTIFICATIONS_ON_USER"
                                 referencedColumnNames="id" referencedTableName="users"/>

        <addForeignKeyConstraint baseColumnNames="resume_id" baseTableName="portfolio_list"
                                 constraintName="FK_PORTFOLIO_LIST_ON_RESUME"
                                 referencedColumnNames="id" referencedTableName="resumes"/>

        <addForeignKeyConstraint baseColumnNames="profession_id" baseTableName="resumes"
